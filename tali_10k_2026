const phaseColors = { base:'#1D9E75', build:'#185FA5', taper:'#993C1D' };
const phaseShown = {};

function cellClass(content, col) {
  if (!content) return '';
  const c = content.toLowerCase();
  if (col === 'sun' && c.includes('race day')) return 'cx';
  if ((col === 'mon' || col === 'wed') && (c.includes('long run') || c.includes('⚠️ long'))) return 'cl';
  if ((col === 'wed' || col === 'mon') && (c.includes('quality') || c.includes('race-pace') || c.includes('sharpener'))) return 'cq';
  if (col === 'wed' && c.includes('strength')) return 'cs';
  if (col === 'fri' && c.includes('run club')) return 'ce';
  if (col === 'fri' && c.includes('strength')) return 'cs';
  if ((col === 'tue' || col === 'thu') && c.includes('hockey')) return 'ch';
  if ((col === 'sat') && (c.includes('🏑') || c.includes('🏒') || c.includes('hockey'))) return 'ch';
  if (col === 'fri' && c.includes('rest') && !c.includes('strength')) return 'cr';
  if (col === 'sun' && c.includes('rest')) return 'cr';
  if (col === 'mon' && c.includes('rest')) return 'cr';
  if (col === 'thu' && c.includes('rest')) return 'cr';
  if (col === 'sat' && c.includes('rest')) return 'cr';
  if (col === 'sat' && c.includes('bye')) return 'ce';
  if (c.includes('easy run') || c.includes('easy 4') || c.includes('easy 5') || c.includes('easy 3') || c.includes('shake-out') || (c.includes('easy') && col === 'wed' && !c.includes('strength'))) return 'ce';
  return '';
}

const cols = ['mon','tue','wed','thu','fri','sat','sun'];
const body = document.getElementById('schedBody');

weeks.forEach(w => {
  if (w.label && !phaseShown[w.phase]) {
    phaseShown[w.phase] = true;
    const hdr = document.createElement('tr');
    hdr.className = 'phase-row';
    hdr.innerHTML = `<td colspan="9">${w.label}</td>`;
    body.appendChild(hdr);
  }
  const tr = document.createElement('tr');
  const pc = phaseColors[w.phase] || '#888';
  tr.innerHTML = `
    <td class="week-cell" style="border-left:3px solid ${pc};padding-left:9px;">
      <div>Wk ${w.n}</div>
      <div class="week-date">${w.dates}</div>
    </td>
    ${cols.map(c => {
      const cls = cellClass(w[c]||'', c);
      const txt = (w[c]||'').replace(/\n/g,'<br>');
      return `<td class="${cls}">${txt||'—'}</td>`;
    }).join('')}
    <td class="km-cell">${w.km} km</td>
  `;
  body.appendChild(tr);
});

function showTab(id, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  btn.classList.add('active');
}
